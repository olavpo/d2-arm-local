#!/bin/bash
set -euo pipefail
IFS=$'\n\t'

# Load common functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/d2-lib.sh"

# Check for required environment variable
if [ -z "${DHIS2_BASE:-}" ]; then
  echo "Error: DHIS2_BASE environment variable not set"
  exit 1
fi
#       ____  __  ______________
#      / __ \/ / / /  _/ ___/__ \
#     / / / / /_/ // / \__ \__/ /
#    / /_/ / __  // / ___/ / __/
#   /_____/_/ /_/___//____/____/
#
#   DHIS2 instance log viewer for Docker containers

if [ "$#" -ne 1 ]; then
  echo "usage: d2-logtail <instance name>"
  exit 1
fi

INSTANCE=$1

# Find the tomcat container using helper function
CONTAINER=$(resolve_tomcat_container "$INSTANCE") || {
  echo "Error: Tomcat container for instance $INSTANCE not found"
  exit 1
}

echo "Tailing logs for DHIS2 instance: $INSTANCE"
echo "Showing last 1000 lines and following in real-time..."
docker logs -f --tail=1000 "$CONTAINER"
