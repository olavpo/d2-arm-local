#   /_____/_/ /_/___//____/____/
#
#   DHIS2 instance shutdown script using d2 cluster CLI

set -euo pipefail
IFS=$'\n\t'

# Check for required environment variable
if [ -z "${DHIS2_BASE:-}" ]; then
  echo "Error: DHIS2_BASE environment variable not set"
  exit 1
fi

if [ "$#" -ne 1 ]; then
  echo "usage: d2-shutdown <instance name>"
  exit 1
fi

INSTANCE=$1

echo "Shutting down DHIS2 instance: $INSTANCE"
cd "$DHIS2_BASE/$INSTANCE"
docker compose down

echo "DHIS2 instance $INSTANCE has been stopped"
