#!/bin/bash
#       ____  __  ______________
#      / __ \/ / / /  _/ ___/__ \
#     / / / / /_/ // / \__ \__/ /
#    / /_/ / __  // / ___/ / __/
#   /_____/_/ /_/___//____/____/
#
#   Script to delete DHIS2 instance using plain Tomcat Docker

set -euo pipefail
IFS=$'\n\t'

# Check for required environment variable
if [ -z "${DHIS2_BASE:-}" ]; then
  echo "Error: DHIS2_BASE environment variable not set"
  exit 1
fi

if [ $# -eq 0 ]; then
  echo "Usage: $0 <instance name>"
  exit 1
fi

INSTANCE=$1
DHIS2_HOME="$DHIS2_BASE/$INSTANCE"

if [ ! -d "$DHIS2_HOME" ]; then
  echo "Error: Instance $INSTANCE does not exist"
  exit 1
fi

echo "Deleting DHIS2 instance: $INSTANCE"

# Stop and remove containers
cd "$DHIS2_HOME"
docker compose down -v

# Remove data directory
rm -rf "$DHIS2_HOME"

echo "✅ DHIS2 instance $INSTANCE deleted successfully"
echo "  All containers stopped and removed"
echo "  Host directory $DHIS2_HOME deleted"
